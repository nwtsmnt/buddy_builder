doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Study Buddies - Home
    link(rel="stylesheet", href="/styles.css")
  body
    .overlay
      header
        h1 Buddy Builder
        nav
          ul
            li
              a(href="/home") Study Buddies
            li
              input(type="text" placeholder="Search")
              button Search
      hr
      main
        .posts
          each post in posts
            .post
              .post-header
                h2= post.title
                p= post.name
              .post-content
                img(src=post.image, alt="Post Image")
                p= post.content
              .post-footer
                p Posted by: #{post.username}
                button Comments
        .groups
          h2 Groups
          ul
            each group in groups
              li
                button= group.name
