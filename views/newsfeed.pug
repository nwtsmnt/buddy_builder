doctype html
html(lang="en")
  head
    title Buddy Builder
    link(rel="stylesheet" href="https://cdn.tailwindcss.com")
  body(class="flex h-screen w-full")

    // Sidebar
    aside(class="w-1/5 bg-gray-200 p-4 space-y-4")
      h1(class="text-2xl font-bold") Buddy Builder
      button(class="w-full bg-gray-600 text-white p-2 rounded") My Profile
      button(class="w-full bg-gray-600 text-white p-2 rounded") Chats
      button(class="w-full bg-gray-600 text-white p-2 rounded") Add Post
      button(class="w-full bg-gray-600 text-white p-2 rounded") About Us
      button(class="w-full bg-gray-600 text-white p-2 rounded") Log-Out

    // Main Content
    main(class="flex-1 p-4 overflow-auto")
      form(class="flex gap-2 mb-4")
        input(type="text" placeholder="Search..." class="flex-1 border p-2 rounded")
        button(type="submit" class="bg-gray-600 text-white p-2 rounded") Search

      // Sample Post
      .card(class="mb-4 p-4 bg-white rounded-lg shadow")
        h2(class="text-lg font-bold") Post Title
        .w-full.h-40.bg-gray-300.my-2
        .flex.justify-between.text-sm.font-semibold
          span User's Name
          span Post Time
        p(class="mt-2 text-sm") This is a description of the post .....
        .flex.justify-end.mt-2
          svg.w-5.h-5.cursor-pointer(xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor")
            path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16h6M4 8h16a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V10a2 2 0 012-2z")

    // Groups Section
    aside(class="w-1/5 bg-gray-200 p-4")
      h2(class="text-xl font-bold mb-4") Groups
      button(class="w-full mb-2 bg-gray-600 text-white p-2 rounded") Group 1
      button(class="w-full mb-2 bg-gray-600 text-white p-2 rounded") Group 2
      button(class="w-full bg-gray-600 text-white p-2 rounded") Group 3
